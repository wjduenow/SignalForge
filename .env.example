# SignalForge Snowflake e2e test environment — TEMPLATE.
#
# Copy to .env and fill in your own values:
#     cp .env.example .env
#     $EDITOR .env
#     set -a; source .env; set +a   # export into your shell
#
# .env is gitignored (.gitignore:14) — your filled-in secrets stay local.
# Placeholders only below; never commit real credentials.
#
# Full walkthrough (cost guardrails FIRST): docs/snowflake-e2e-setup.md
# Run the gated tests:  uv run pytest -m snowflake --no-cov

# --- Required for every live Snowflake test ---
SF_RUN_SNOWFLAKE=1
SNOWFLAKE_ACCOUNT=        # e.g. myorg-account1  or  xy12345.us-east-1 (no https://)
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=      # an XS warehouse — see docs cost guardrails

# --- Required for the full-stack e2e (draft + grade); omit for offline/EXPLAIN-only ---
ANTHROPIC_API_KEY=       # starts with sk-ant-...

# --- Optional (sensible defaults apply in the fixture profile) ---
SNOWFLAKE_ROLE=          # override default role if it lacks SNOWFLAKE_SAMPLE_DATA access
SNOWFLAKE_DATABASE=      # defaults to SNOWFLAKE_SAMPLE_DATA
SNOWFLAKE_SCHEMA=        # defaults to TPCH_SF1
